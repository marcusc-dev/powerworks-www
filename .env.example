# OpenAI API Key (for web search functionality)
OPENAI_API_KEY=

# Gemini API Key (required for Voice Assistant - Glenn)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Google Cloud Text-to-Speech (Neural2 voices for high-quality TTS)
# Without this, the voice assistant falls back to browser TTS (robotic)
#
# Setup steps:
# 1. Go to https://console.cloud.google.com/
# 2. Create a project or select existing
# 3. Enable the Cloud Text-to-Speech API
# 4. Create a service account with "Cloud Text-to-Speech User" role
# 5. Download the JSON key file
# 6. Paste the entire JSON content below (for Vercel/production):
GOOGLE_CLOUD_CREDENTIALS=
#
# Or for local development, set the path to the JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Daily Analytics Report ---
# See docs/analytics-setup.md for full setup instructions.

# GA4 property ID (numeric, e.g. 123456789)
GA4_PROPERTY_ID=

# Google service account for GA4 + Search Console access
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Google Search Console site URL (e.g. sc-domain:powerworksgarage.com)
GSC_SITE_URL=sc-domain:powerworksgarage.com

# Brevo API key (used for booking notifications + daily report emails)
BREVO_API_KEY=

# Optional: secret to protect the /api/daily-report cron endpoint
# CRON_SECRET=
